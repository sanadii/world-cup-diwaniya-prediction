# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for Edge Functions / server-side (never expose client-side)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Score sync (API-Football) — server-side only via Supabase Edge Functions
# API_FOOTBALL_KEY=your-api-football-key-here

# Optional: fallback score source
# FOOTBALL_DATA_ORG_KEY=your-football-data-key-here
