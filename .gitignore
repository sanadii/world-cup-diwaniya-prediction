*.tsbuildinfo

.vercel

# Graphify — ignore generated artifacts, keep hand-authored dashboard + sync scripts
graphify-out/*
!graphify-out/dashboard.html
!graphify-out/sync-dashboard.py
!graphify-out/watch-sync.py
!graphify-out/start-watch.ps1
!graphify-out/start-watch.sh
!graphify-out/.dashboard_name
